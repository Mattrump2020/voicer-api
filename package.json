{
  "name": "voicer-api",
  "version": "1.0.0",
  "description": "Voicer AI Backend API — Express + Drizzle + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node --files src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node src/db/seeds/languages.seed.ts",
    "typecheck": "tsc --noEmit",
    "postbuild": "drizzle-kit migrate"
  },
  "dependencies": {
    "express": "^4.18.2",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.3",
    "@supabase/supabase-js": "^2.43.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "nodemailer": "^6.9.7",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "archiver": "^6.0.1",
    "json2csv": "^5.0.7",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "drizzle-kit": "^0.21.4",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.14",
    "@types/cors": "^2.8.17",
    "@types/archiver": "^6.0.2",
    "@types/json2csv": "^5.0.7",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "nodemon": "^3.0.2"
  }
}

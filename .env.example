# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# SUPABASE — get these from: supabase.com → your project → Settings → API
#
# DATABASE_URL  → Settings → Database → Connection string → URI
#                 looks like: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# SUPABASE_URL  → Settings → API → Project URL
#                 looks like: https://abcdefghij.supabase.co
#
# SUPABASE_SERVICE_ROLE_KEY → Settings → API → service_role key
#   ⚠️  This key bypasses Row Level Security — keep it server-side only, NEVER expose to frontend
#
# SUPABASE_ANON_KEY → Settings → API → anon key
#   Safe for frontend use — limited permissions
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# The name of the bucket you create in Supabase Storage
# Create it at: supabase.com → your project → Storage → New bucket
# Set it to PRIVATE (not public)
SUPABASE_AUDIO_BUCKET=voicer-audio

# ─────────────────────────────────────────────────────────────
# JWT — generate a strong secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_64_char_hex_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────────────────────
# EMAIL (Gmail SMTP)
#
# SMTP_HOST     → always smtp.gmail.com for Gmail
# SMTP_PORT     → always 587 for Gmail (uses STARTTLS)
# SMTP_USER     → your Gmail address
# SMTP_PASS     → NOT your Gmail password — you need a Google App Password:
#                 1. myaccount.google.com → Security → 2-Step Verification (must be ON)
#                 2. Scroll down → App passwords
#                 3. Create one called "Voicer API"
#                 4. Google gives you a 16-char code — use that here (no spaces)
# EMAIL_FROM    → the "From" name shown in emails — can be anything
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=abcdabcdabcdabcd
EMAIL_FROM=Voicer AI <noreply@voicer.ai>

# ─────────────────────────────────────────────────────────────
# APP URLS
#
# CLIENT_URL → your frontend dev server (Vite default: 5173)
#              Used for: CORS origin, email link destinations
# APP_URL    → this Express API server
#              Used for: constructing internal URLs if needed
# ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# BUSINESS RULES — these are your own numbers, not third-party values
#
# INVITATION_EXPIRY_HOURS   → how long a project invite link stays valid
# RESET_TOKEN_EXPIRY_MINUTES → how long a password reset link stays valid
# ─────────────────────────────────────────────────────────────
INVITATION_EXPIRY_HOURS=72
RESET_TOKEN_EXPIRY_MINUTES=60
